# Backend environment variables

# Database — use one of the options below:
# Option A: explicit URL (takes priority)
DATABASE_URL=sqlite:///./sql_app.db
# Option B: Supabase env vars (set automatically by Vercel when project is linked)
# POSTGRES_URL_NON_POOLING=postgres://postgres.<ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
# POSTGRES_URL=postgres://postgres.<ref>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true

SESSION_SECRET=change-me-to-a-random-64-char-string
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
UPLOAD_DIR=uploads
ADMIN_PHONES=
